rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function hasEmail() {
      return request.auth != null && request.auth.token.email != null;
    }

    // Products — public read, admin write only
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin()
        && request.resource.data.keys().hasAll(['name', 'price', 'category'])
        && request.resource.data.name is string
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Categories — public read, admin write only
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Customers — owner can read own, admin can read all
    match /customers/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow create: if hasEmail() && isOwner(customerId);
      allow update: if isOwner(customerId) || isAdmin();
      allow delete: if false;
    }

    // Orders — owner read own, admin read/write all, auth required to create
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.customer_id) || isAdmin();
      allow create: if hasEmail()
        && request.resource.data.customer_id == request.auth.uid
        && request.resource.data.keys().hasAll(['items', 'total', 'shipping']);
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Custom Orders — owner read own, admin read/write all
    match /customOrders/{orderId} {
      allow read: if isOwner(resource.data.customer_id) || isAdmin();
      allow create: if hasEmail()
        && request.resource.data.customer_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Carts — owner only, no one else can touch
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Contact Messages — anyone authed can create, admin read/delete
    match /contactMessages/{msgId} {
      allow create: if hasEmail()
        && request.resource.data.keys().hasAll(['name', 'email', 'message']);
      allow read: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // Newsletter — anyone can subscribe
    match /newsletter/{docId} {
      allow create: if hasEmail();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Admin — admin doc is read-only, never writable from client
    match /admin/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

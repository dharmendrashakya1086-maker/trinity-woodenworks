rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is admin
    function isAdmin() {
      return exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Helper: check if user owns the document
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Products — public read, admin write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Categories — public read, admin write
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Customers — owner read, admin read/write
    match /customers/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow create: if request.auth != null;
      allow update: if isOwner(customerId) || isAdmin();
      allow delete: if false;
    }

    // Orders — owner read, admin read/write, anyone create
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.customer_id) || isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Custom Orders — owner read, admin read/write, anyone create
    match /customOrders/{orderId} {
      allow read: if isOwner(resource.data.customer_id) || isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Carts — owner only
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Contact Messages — anyone create, admin read
    match /contactMessages/{msgId} {
      allow create: if true;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // Newsletter — anyone subscribe, admin read
    match /newsletter/{email} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Admin — admin only (self)
    match /admin/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

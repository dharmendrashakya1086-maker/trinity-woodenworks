<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1>Track Your Order</h1>
    <p><%= customer ? 'Click any order to track its status' : 'Enter your order number to check status' %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="track-order-section">

      <% if (customer && myOrders.length > 0 && !order) { %>
        <div class="my-orders-list">
          <h2 class="section-title"><i class="fas fa-box"></i> Your Recent Orders</h2>
          <% myOrders.forEach(o => { %>
            <form action="/track-order" method="POST" style="display:inline">
              <input type="hidden" name="order_number" value="<%= o.order_number %>">
              <button type="submit" class="order-track-card">
                <div class="order-track-left">
                  <div class="order-track-icon">
                    <% if (o.order_status === 'delivered') { %>
                      <i class="fas fa-check-circle" style="color:#00e676"></i>
                    <% } else if (o.order_status === 'cancelled') { %>
                      <i class="fas fa-times-circle" style="color:#ff1744"></i>
                    <% } else if (o.order_status === 'shipped') { %>
                      <i class="fas fa-truck" style="color:#ffab00"></i>
                    <% } else { %>
                      <i class="fas fa-clock" style="color:var(--primary)"></i>
                    <% } %>
                  </div>
                  <div class="order-track-info">
                    <h3><%= o.order_number %></h3>
                    <p><%= new Date(o.created_at).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %></p>
                  </div>
                </div>
                <div class="order-track-right">
                  <span class="badge badge-<%= o.order_status %>"><%= o.order_status %></span>
                  <span class="order-track-total">₹<%= o.total.toLocaleString() %></span>
                  <i class="fas fa-chevron-right"></i>
                </div>
              </button>
            </form>
          <% }) %>
        </div>
      <% } %>

      <% if (!customer) { %>
        <form action="/track-order" method="POST" class="track-form">
          <div class="track-input-group">
            <input type="text" name="order_number" placeholder="Enter Order Number (e.g., TW26061234)" value="<%= order ? order.order_number : '' %>" required>
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Track</button>
          </div>
        </form>
      <% } else if (myOrders.length === 0 || order) { %>
        <form action="/track-order" method="POST" class="track-form">
          <div class="track-input-group">
            <input type="text" name="order_number" placeholder="Or enter order number manually" value="<%= order ? order.order_number : '' %>">
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Track</button>
          </div>
        </form>
      <% } %>

      <% if (order) { %>
        <div class="order-tracking-result">
          <div class="order-header-card">
            <div>
              <h2>Order #<%= order.order_number %></h2>
              <p>Placed on <%= new Date(order.created_at).toLocaleDateString('en-IN', {day:'numeric', month:'long', year:'numeric'}) %></p>
            </div>
            <div class="order-total-badge">Total: ₹<%= order.total.toLocaleString() %></div>
          </div>

          <div class="tracking-steps">
            <div class="tracking-step <%= ['confirmed','processing','shipped','delivered'].includes(order.order_status) ? 'completed' : (order.order_status === 'pending' ? 'current pending-pulse' : '') %>">
              <div class="step-icon">
                <% if (['confirmed','processing','shipped','delivered'].includes(order.order_status)) { %>
                  <i class="fas fa-check"></i>
                <% } else if (order.order_status === 'pending') { %>
                  <i class="fas fa-clock"></i>
                <% } else { %>
                  <i class="fas fa-times"></i>
                <% } %>
              </div>
              <div class="step-info">
                <% if (['confirmed','processing','shipped','delivered'].includes(order.order_status)) { %>
                  <h4>Order Confirmed</h4>
                  <p>Your order has been accepted by us</p>
                <% } else if (order.order_status === 'pending') { %>
                  <h4>Awaiting Confirmation</h4>
                  <p>We've received your order. We'll confirm it soon!</p>
                <% } else { %>
                  <h4>Order Confirmed</h4>
                  <p>Your order has been received</p>
                <% } %>
              </div>
            </div>
            <div class="tracking-step <%= ['processing','shipped','delivered'].includes(order.order_status) ? 'completed' : (order.order_status === 'confirmed' ? 'current' : '') %>">
              <div class="step-icon"><i class="fas fa-cog"></i></div>
              <div class="step-info">
                <h4>Processing</h4>
                <p>We're preparing your order</p>
              </div>
            </div>
            <div class="tracking-step <%= ['shipped','delivered'].includes(order.order_status) ? 'completed' : (order.order_status === 'processing' ? 'current' : '') %>">
              <div class="step-icon"><i class="fas fa-truck"></i></div>
              <div class="step-info">
                <h4>Shipped</h4>
                <p>Your order is on the way</p>
              </div>
            </div>
            <div class="tracking-step <%= order.order_status === 'delivered' ? 'completed' : '' %>">
              <div class="step-icon"><i class="fas fa-box-open"></i></div>
              <div class="step-info">
                <h4>Delivered</h4>
                <p>Your order has arrived</p>
              </div>
            </div>
          </div>

          <div class="order-details-grid">
            <div class="order-detail-card">
              <h3>Shipping Address</h3>
              <p><%= order.customer_name %></p>
              <p><%= order.customer_address %></p>
              <p><%= order.customer_city %>, <%= order.customer_state %> - <%= order.customer_pincode %></p>
              <p><i class="fas fa-phone"></i> <%= order.customer_phone %></p>
            </div>
            <div class="order-detail-card">
              <h3>Payment Info</h3>
              <p>Method: <%= order.payment_method === 'cod' ? 'Cash on Delivery' : 'Online Payment' %></p>
              <p>Status: <span class="badge badge-<%= order.payment_status %>"><%= order.payment_status %></span></p>
              <p>Subtotal: ₹<%= order.subtotal.toLocaleString() %></p>
              <p>Shipping: <%= order.shipping_cost > 0 ? '₹' + order.shipping_cost : 'Free' %></p>
              <p><strong>Total: ₹<%= order.total.toLocaleString() %></strong></p>
            </div>
          </div>
        </div>
      <% } else if (typeof searched !== 'undefined' && searched) { %>
        <div class="empty-state">
          <i class="fas fa-exclamation-triangle"></i>
          <h3>Order Not Found</h3>
          <p>Please check your order number and try again.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<style>
.my-orders-list { margin-bottom: 30px; }
.my-orders-list .section-title {
  font-size: 1.1rem;
  color: var(--text);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.order-track-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 14px 18px;
  margin-bottom: 8px;
  background: var(--dark-2);
  border: 1px solid var(--border);
  border-radius: 12px;
  cursor: pointer;
  transition: var(--transition);
  text-align: left;
  color: var(--text);
  font-family: var(--font-body);
}
.order-track-card:hover {
  border-color: var(--primary);
  background: rgba(201,169,110,0.05);
  transform: translateX(4px);
}
.order-track-left {
  display: flex;
  align-items: center;
  gap: 14px;
}
.order-track-icon { font-size: 1.4rem; }
.order-track-info h3 {
  font-size: 0.95rem;
  color: #fff;
  margin: 0;
}
.order-track-info p {
  font-size: 0.78rem;
  color: var(--text-muted);
  margin: 2px 0 0;
}
.order-track-right {
  display: flex;
  align-items: center;
  gap: 12px;
}
.order-track-total {
  font-weight: 700;
  color: var(--primary);
  font-size: 0.95rem;
}
.order-track-right .fa-chevron-right {
  color: var(--text-muted);
  font-size: 0.8rem;
}
@media (max-width: 768px) {
  .order-track-card { flex-direction: column; align-items: flex-start; gap: 10px; }
  .order-track-right { width: 100%; justify-content: space-between; }
}
.pending-pulse .step-icon {
  animation: pendingGlow 2s ease-in-out infinite;
}
@keyframes pendingGlow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255,171,0,0.3); }
  50% { box-shadow: 0 0 0 10px rgba(255,171,0,0); }
}
</style>

<%- include('partials/footer') %>

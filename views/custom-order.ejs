<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1>Custom Order</h1>
    <p>Tell us your vision and we'll bring it to life</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="custom-order-page-grid">
      <div class="custom-order-form-section">
        <form class="contact-form" onsubmit="return handleCustomOrder(event)">
          <div class="form-row">
            <div class="form-group">
              <label for="co-name">Your Name *</label>
              <input type="text" id="co-name" required placeholder="Enter your name">
            </div>
            <div class="form-group">
              <label for="co-email">Email Address *</label>
              <input type="email" id="co-email" required placeholder="Enter your email">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="co-phone">Phone Number *</label>
              <input type="tel" id="co-phone" required placeholder="Enter your phone">
            </div>
            <div class="form-group">
              <label for="co-category">Product Type *</label>
              <select id="co-category" required>
                <option value="">Select a category</option>
                <option value="furniture">Furniture</option>
                <option value="kitchenware">Kitchenware</option>
                <option value="decor">Home Decor</option>
                <option value="gift">Personalized Gift</option>
                <option value="nameplate">Nameplate</option>
                <option value="frame">Frame</option>
                <option value="toy">Toy / Game</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="co-wood">Preferred Wood Type</label>
              <select id="co-wood">
                <option value="">No preference</option>
                <option value="sheesham">Sheesham (Rosewood)</option>
                <option value="teak">Teak</option>
                <option value="mango">Mango Wood</option>
                <option value="acacia">Acacia</option>
                <option value="oak">Oak</option>
                <option value="pine">Pine</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="co-budget">Budget Range</label>
              <select id="co-budget">
                <option value="">Select budget</option>
                <option value="under1000">Under &#x20B9;1,000</option>
                <option value="1000-3000">&#x20B9;1,000 - &#x20B9;3,000</option>
                <option value="3000-5000">&#x20B9;3,000 - &#x20B9;5,000</option>
                <option value="5000-10000">&#x20B9;5,000 - &#x20B9;10,000</option>
                <option value="above10000">Above &#x20B9;10,000</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="co-dimensions">Dimensions (if applicable)</label>
            <input type="text" id="co-dimensions" placeholder="e.g. 4ft x 2ft x 3ft">
          </div>
          <div class="form-group">
            <label for="co-description">Describe Your Custom Order *</label>
            <textarea id="co-description" rows="6" required placeholder="Tell us about your idea — what you want, preferred design, any references, special requirements..."></textarea>
          </div>
          <div class="form-group">
            <label for="co-image">Reference Image (optional)</label>
            <input type="file" id="co-image" accept="image/*">
            <small style="color: var(--text-muted);">Upload a sketch or reference photo</small>
          </div>
          <button type="submit" class="btn btn-primary btn-lg btn-glow" style="width: 100%;"><i class="fas fa-paper-plane"></i> Submit Custom Order Request</button>
        </form>
        <div id="customOrderSuccess" class="alert alert-success" style="display:none; margin-top: 20px;">
          <i class="fas fa-check-circle"></i> Thank you! Your custom order request has been submitted. Our team will contact you within 24 hours to discuss your project.
        </div>
      </div>

      <div class="custom-order-info">
        <div class="co-info-card">
          <div class="co-info-icon"><i class="fas fa-comments"></i></div>
          <h3>How It Works</h3>
          <div class="co-steps">
            <div class="co-step">
              <span class="co-step-num">1</span>
              <div>
                <h4>Submit Your Idea</h4>
                <p>Fill out the form with your design requirements</p>
              </div>
            </div>
            <div class="co-step">
              <span class="co-step-num">2</span>
              <div>
                <h4>Free Consultation</h4>
                <p>We'll call you to discuss details and feasibility</p>
              </div>
            </div>
            <div class="co-step">
              <span class="co-step-num">3</span>
              <div>
                <h4>Design Approval</h4>
                <p>We share a sketch/mockup for your approval</p>
              </div>
            </div>
            <div class="co-step">
              <span class="co-step-num">4</span>
              <div>
                <h4>Crafting & Delivery</h4>
                <p>We handcraft your piece and deliver it to you</p>
              </div>
            </div>
          </div>
        </div>
        <div class="co-info-card">
          <div class="co-info-icon"><i class="fas fa-clock"></i></div>
          <h3>Typical Timeline</h3>
          <p style="color: var(--text-light); line-height: 1.7;">Simple items: <strong>5-7 days</strong><br>Complex furniture: <strong>10-21 days</strong><br>Large projects: <strong>Custom timeline</strong></p>
        </div>
        <div class="co-info-card">
          <div class="co-info-icon"><i class="fas fa-shield-halved"></i></div>
          <h3>Our Guarantee</h3>
          <p style="color: var(--text-light); line-height: 1.7;">100% handcrafted with premium wood.不满意? We offer free revisions during the design phase.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
function handleCustomOrder(e) {
  e.preventDefault();
  var form = e.target;
  var btn = form.querySelector('button[type="submit"]');
  var data = {
    name: document.getElementById('co-name').value.trim(),
    email: document.getElementById('co-email').value.trim(),
    phone: document.getElementById('co-phone').value.trim(),
    category: document.getElementById('co-category').value,
    wood: document.getElementById('co-wood').value,
    budget: document.getElementById('co-budget').value,
    dimensions: document.getElementById('co-dimensions').value.trim(),
    description: document.getElementById('co-description').value.trim()
  };
  if (!data.name || !data.email || !data.phone || !data.category || !data.description) {
    alert('Please fill all required fields');
    return false;
  }
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';
  fetch('/api/custom-order', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  }).then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.success) {
        form.style.display = 'none';
        document.getElementById('customOrderSuccess').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        alert(d.error || 'Failed to submit');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Custom Order Request';
      }
    }).catch(function() {
      alert('Something went wrong');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Custom Order Request';
    });
  return false;
}
</script>

<style>
.custom-order-page-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 48px;
  align-items: start;
}
.co-info-card {
  padding: 24px;
  border-radius: 16px;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  margin-bottom: 20px;
}
.co-info-icon {
  width: 48px; height: 48px;
  border-radius: 14px;
  background: rgba(201,169,110,0.1);
  border: 1px solid rgba(201,169,110,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-size: 1.2rem;
  margin-bottom: 16px;
}
.co-info-card h3 { font-size: 1.1rem; margin-bottom: 12px; }
.co-steps { display: flex; flex-direction: column; gap: 16px; }
.co-step {
  display: flex;
  align-items: flex-start;
  gap: 14px;
}
.co-step-num {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: rgba(201,169,110,0.1);
  border: 1px solid rgba(201,169,110,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-weight: 700;
  font-size: 0.85rem;
  flex-shrink: 0;
}
.co-step h4 { font-size: 0.95rem; margin-bottom: 2px; }
.co-step p { font-size: 0.8rem; color: var(--text-muted); margin: 0; }
@media (max-width: 768px) {
  .custom-order-page-grid { grid-template-columns: 1fr; }
}
</style>

<%- include('partials/footer') %>

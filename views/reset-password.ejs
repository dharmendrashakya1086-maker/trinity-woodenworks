<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1>Reset Password</h1>
    <p>Enter the code and your new password</p>
    <div class="breadcrumb">
      <a href="/">Home</a> <i class="fas fa-chevron-right"></i> <a href="/login">Login</a> <i class="fas fa-chevron-right"></i> <span>Reset Password</span>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="auth-container">
      <div class="auth-card">
        <div class="auth-logo">
          <div class="logo-circle">
            <img src="/images/Trinity Woodenworks Logo.png" alt="Trinity Woodenworks">
          </div>
        </div>
        <h2>Reset Your Password</h2>
        <p class="auth-subtitle">Enter the 6-digit code sent to <strong><%= email %></strong></p>

        <% if (error) { %>
          <div class="auth-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
        <% } %>

        <% if (success) { %>
          <div class="auth-success"><i class="fas fa-check-circle"></i> <%= success %></div>
        <% } %>

        <form action="/reset-password" method="POST" class="auth-form" id="resetForm">
          <input type="hidden" name="email" value="<%= email %>">

          <div class="form-group">
            <label><i class="fas fa-key"></i> Verification Code</label>
            <input type="text" name="code" required placeholder="Enter 6-digit code" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code" class="verification-input" id="codeInput">
          </div>

          <p class="verification-hint"><i class="fas fa-envelope"></i> Check your email for the 6-digit code</p>

          <div class="form-group">
            <label><i class="fas fa-lock"></i> New Password</label>
            <input type="password" name="new_password" required placeholder="Min 6 characters" minlength="6" id="newPassword">
          </div>
          <div class="form-group">
            <label><i class="fas fa-lock"></i> Confirm New Password</label>
            <input type="password" name="confirm_password" required placeholder="Re-enter new password" minlength="6" id="confirmPassword">
          </div>

          <button type="submit" class="btn btn-primary btn-lg btn-block"><i class="fas fa-check-circle"></i> Reset Password</button>
        </form>

        <div class="auth-footer">
          <a href="/login" style="display:inline-flex; align-items:center; gap:6px;"><i class="fas fa-arrow-left"></i> Back to Login</a>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>

<%- include('partials/header') %>

<section class="hero hero-3d">
  <div class="hero-bg"></div>
  <div class="container hero-content">
    <div class="hero-badge badge-glass floating">Handcrafted with Love</div>
    <h1 class="gradient-text">Trinity Woodenworks</h1>
    <p class="hero-subtitle">Crafted with Passion, Built to Last</p>
    <p class="hero-desc">Premium handcrafted wooden items made by three friends who share a passion for woodworking. Each piece tells a story of craftsmanship and dedication.</p>
    <div class="hero-actions">
      <a href="/shop" class="btn btn-primary btn-lg btn-glow"><i class="fas fa-shopping-bag"></i> Shop Now</a>
      <a href="/about" class="btn btn-outline btn-lg"><i class="fas fa-info-circle"></i> Our Story</a>
    </div>
    <div class="hero-founders">
      <span>Founded by Anshuman, Sachin & Sankalp</span>
    </div>
  </div>
</section>

<!-- Trust Badges -->
<section class="section" style="padding-top: 60px; padding-bottom: 40px;">
  <div class="container">
    <div class="stats-grid stagger-children">
      <div class="trust-badge reveal">
        <div class="trust-badge-icon"><i class="fas fa-truck-fast"></i></div>
        <div class="trust-badge-title">Free Shipping</div>
        <div class="trust-badge-text">On orders above ₹1,000</div>
      </div>
      <div class="trust-badge reveal">
        <div class="trust-badge-icon"><i class="fas fa-shield-halved"></i></div>
        <div class="trust-badge-title">Quality Assured</div>
        <div class="trust-badge-text">Premium wood, built to last</div>
      </div>
      <div class="trust-badge reveal">
        <div class="trust-badge-icon"><i class="fas fa-rotate-left"></i></div>
        <div class="trust-badge-title">Easy Returns</div>
        <div class="trust-badge-text">7-day return policy</div>
      </div>
      <div class="trust-badge reveal">
        <div class="trust-badge-icon"><i class="fas fa-headset"></i></div>
        <div class="trust-badge-title">24/7 Support</div>
        <div class="trust-badge-text">We're here to help</div>
      </div>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="section">
  <div class="container">
    <div class="stats-grid stagger-children">
      <div class="stat-item reveal">
        <div class="counter-value" data-count="<%= stats.products %>">0</div>
        <div class="counter-label">Products</div>
      </div>
      <div class="stat-item reveal">
        <div class="counter-value" data-count="500">0</div>
        <div class="counter-label">Happy Customers</div>
      </div>
      <div class="stat-item reveal">
        <div class="counter-value" data-count="50">0</div>
        <div class="counter-label">Custom Designs</div>
      </div>
      <div class="stat-item reveal">
        <div class="counter-value" data-count="5">0</div>
        <div class="counter-label">Years Experience</div>
      </div>
    </div>
  </div>
</section>

<section class="features">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag">Why Choose Us</span>
      <h2>Crafted for You</h2>
      <p>Every piece reflects our commitment to quality</p>
    </div>
    <div class="features-grid stagger-children">
      <div class="feature-card reveal">
        <div class="feature-icon"><i class="fas fa-hand-sparkles"></i></div>
        <h3>100% Handcrafted</h3>
        <p>Every piece is carefully handcrafted by skilled artisans</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon"><i class="fas fa-leaf"></i></div>
        <h3>Eco-Friendly</h3>
        <p>Made from sustainably sourced natural wood</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon"><i class="fas fa-truck"></i></div>
        <h3>Free Shipping</h3>
        <p>Free delivery on orders above ₹1,000</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
        <h3>Quality Assured</h3>
        <p>Premium quality wood with lifetime durability</p>
      </div>
    </div>
  </div>
</section>

<% if (featuredCategories.length > 0) { %>
<section class="section featured-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag">Our Collection</span>
      <h2>Featured Categories</h2>
      <p>Explore our handcrafted collections by category</p>
    </div>
    <div class="categories-grid home-categories-grid stagger-children">
      <% featuredCategories.forEach(cat => { %>
        <a href="/shop?category=<%= cat.id %>" class="category-tile reveal">
          <div class="category-tile-image">
            <% if (cat.image) { %>
              <img src="/images/<%= cat.image %>" alt="<%= cat.name %>">
            <% } else { %>
              <div class="category-tile-icon">
                <i class="fas <%= cat.icon || 'fa-layer-group' %>"></i>
              </div>
            <% } %>
            <div class="category-tile-overlay"></div>
          </div>
          <div class="category-tile-content">
            <h3><%= cat.name %></h3>
            <p><%= cat.description %></p>
            <span class="category-tile-count"><%= cat.product_count %> product<%= cat.product_count !== 1 ? 's' : '' %></span>
            <span class="category-tile-btn">View Collection <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
      <% }) %>
    </div>
    <div class="section-footer reveal">
      <a href="/categories" class="btn btn-outline">View All Categories <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>
<% } %>

<% if (latest.length > 0) { %>
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-tag">New Arrivals</span>
      <h2>Latest Products</h2>
      <p>Check out our newest handcrafted pieces</p>
    </div>
    <div class="products-grid home-products-grid stagger-children">
      <% latest.forEach(product => { %>
        <a href="/product/<%= product.id %>" class="product-card reveal">
          <div class="product-image">
            <% if (product.image) { %>
              <img src="/images/<%= product.image %>" alt="<%= product.name %>">
            <% } else { %>
              <div class="product-placeholder"><i class="fas fa-image"></i></div>
            <% } %>
            <% if (product.discount_percent > 0) { %>
              <span class="product-badge sale"><%= product.discount_percent %>% OFF</span>
            <% } %>
            <button class="card-share-btn" onclick="event.stopPropagation(); shareProduct(<%= product.id %>, '<%= product.name.replace(/'/g, "\\'") %>', <%= product.price %>)" title="Share">
              <i class="fas fa-share-alt"></i>
            </button>
          </div>
          <div class="product-info">
            <span class="product-category"><%= product.category_name || 'Uncategorized' %></span>
            <h3 class="product-name"><%= product.name %></h3>
            <div class="product-price">
              <% if (product.discount_percent > 0) { %>
                <span class="price-current">₹<%= product.price.toLocaleString() %></span>
                <span class="price-old">₹<%= (product.mrp || product.price).toLocaleString() %></span>
              <% } else { %>
                <span class="price-current">₹<%= product.price.toLocaleString() %></span>
              <% } %>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
    <div class="section-footer reveal">
      <a href="/shop" class="btn btn-primary">View All Products <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>
<% } %>


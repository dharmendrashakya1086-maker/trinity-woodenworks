<!-- ===== FEATURED CATEGORIES ===== -->
<% if (featuredCategories.length > 0) { %>
<section class="ss-section">
  <div class="ss-section-header">
    <h2 class="ss-section-title">Shop by Category</h2>
    <a href="/categories" class="ss-link">View All <span>&rarr;</span></a>
  </div>
  <div class="ss-category-grid">
    <% featuredCategories.forEach(function(cat) { %>
    <a href="/shop?category=<%= cat.id %>" class="ss-category-card">
      <div class="ss-category-image">
        <% if (cat.image) { %>
          <img src="<%= cat.image %>" alt="<%= cat.name %>" loading="lazy">
        <% } else { %>
          <div class="ss-category-icon"><i class="<%= cat.icon || 'fas fa-box' %>"></i></div>
        <% } %>
      </div>
      <div class="ss-category-info">
        <h3 class="ss-category-name"><%= cat.name %></h3>
        <p class="ss-category-desc"><%= cat.description || '' %></p>
        <span class="ss-category-count"><%= cat.product_count %> products</span>
      </div>
    </a>
    <% }); %>
  </div>
</section>
<% } %>

<!-- ===== LATEST PRODUCTS ===== -->
<% if (latest.length > 0) { %>
<section class="ss-section ss-section--dark">
  <div class="ss-section-header">
    <h2 class="ss-section-title">Latest Arrivals</h2>
    <a href="/shop" class="ss-link">Shop All <span>&rarr;</span></a>
  </div>
  <div class="ss-product-grid">
    <% latest.forEach(function(product) { %>
    <a href="/product/<%= product.id %>" class="ss-product-card">
      <div class="ss-product-image">
        <% if (product.image) { %>
          <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy">
        <% } else { %>
          <div class="ss-product-placeholder"><i class="fas fa-image"></i></div>
        <% } %>
        <% if (product.discount_percent) { %>
          <span class="ss-product-badge">-<%= product.discount_percent %>%</span>
        <% } %>
        <div class="ss-product-overlay">
          <span class="ss-product-quick">Quick View</span>
        </div>
      </div>
      <div class="ss-product-info">
        <span class="ss-product-category"><%= product.category_name || '' %></span>
        <h3 class="ss-product-name"><%= product.name %></h3>
        <div class="ss-product-pricing">
          <span class="ss-product-price">&#8377;<%= product.price.toFixed(2) %></span>
          <% if (product.mrp && product.mrp > product.price) { %>
            <span class="ss-product-mrp">&#8377;<%= product.mrp.toFixed(2) %></span>
          <% } %>
        </div>
      </div>
    </a>
    <% }); %>
  </div>
</section>
<% } %>


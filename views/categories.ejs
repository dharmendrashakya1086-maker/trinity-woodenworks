<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1>Our Collections</h1>
    <p>Choose a category to explore the products inside it</p>
    <div class="breadcrumb">
      <a href="/">Home</a> <i class="fas fa-chevron-right"></i> <span>Shop</span>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="categories-top-bar">
      <div class="categories-search">
        <i class="fas fa-search"></i>
        <input type="text" id="categorySearch" placeholder="Search categories..." oninput="filterCategories()">
      </div>
      <a href="/shop" class="btn btn-outline-light btn-sm">
        <i class="fas fa-th"></i> Show All Products
      </a>
    </div>

    <div class="categories-grid" id="categoriesGrid">
      <% categories.forEach(cat => { %>
        <a href="/shop?category=<%= cat.id %>" class="category-tile" data-name="<%= cat.name.toLowerCase() %>" data-desc="<%= (cat.description || '').toLowerCase() %>">
          <div class="category-tile-image">
            <% if (cat.image) { %>
              <img src="/images/<%= cat.image %>" alt="<%= cat.name %>">
            <% } else { %>
              <div class="category-tile-icon">
                <i class="fas <%= cat.icon || 'fa-layer-group' %>"></i>
              </div>
            <% } %>
            <div class="category-tile-overlay"></div>
          </div>
          <div class="category-tile-content">
            <h3><%= cat.name %></h3>
            <p><%= cat.description %></p>
            <span class="category-tile-count"><%= cat.product_count %> product<%= cat.product_count !== 1 ? 's' : '' %></span>
            <span class="category-tile-btn">View Collection <i class="fas fa-arrow-right"></i></span>
          </div>
        </a>
      <% }) %>
    </div>

    <div class="categories-empty" id="categoriesEmpty" style="display:none">
      <i class="fas fa-search"></i>
      <p>No categories found matching your search</p>
    </div>
  </div>
</section>

<section class="section cta-section">
  <div class="container">
    <div class="cta-card">
      <h2>Can't Find What You're Looking For?</h2>
      <p>We do custom orders! Tell us what you need and we'll craft it for you.</p>
      <div class="cta-actions">
        <a href="/custom-order" class="btn btn-primary btn-glow btn-lg">Custom Order</a>
        <a href="/track-custom-order" class="btn btn-outline-light btn-lg"><i class="fas fa-search"></i> Track Custom Order</a>
        <a href="/shop" class="btn btn-outline-light btn-lg">Browse All Products</a>
      </div>
    </div>
  </div>
</section>

<script>
function filterCategories() {
  const term = document.getElementById('categorySearch').value.toLowerCase();
  const tiles = document.querySelectorAll('.category-tile');
  let visible = 0;
  tiles.forEach(tile => {
    const name = tile.dataset.name || '';
    const desc = tile.dataset.desc || '';
    const match = name.includes(term) || desc.includes(term);
    tile.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  document.getElementById('categoriesEmpty').style.display = visible === 0 ? 'block' : 'none';
}
</script>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1>My Account</h1>
    <p>Manage your profile and settings</p>
    <div class="breadcrumb">
      <a href="/">Home</a> <i class="fas fa-chevron-right"></i> <span>Account</span>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="account-layout">

      <!-- ========== SIDEBAR ========== -->
      <aside class="account-sidebar">
        <div class="account-profile-card">
          <div class="account-avatar-ring">
            <div class="account-avatar-glow"></div>
            <div class="account-avatar-inner">
              <span class="account-avatar-initials"><%= customer.name.charAt(0).toUpperCase() %></span>
            </div>
            <div class="account-avatar-ring-border"></div>
          </div>
          <h3 class="account-user-name"><%= customer.name %></h3>
          <p class="account-user-email"><%= customer.email %></p>
          <div class="account-user-badge">
            <span class="account-verified-dot"></span> Verified Account
          </div>
        </div>

        <nav class="account-nav">
          <a href="/account" class="account-nav-link active">
            <span class="account-nav-icon"><i class="fas fa-user-edit"></i></span>
            <span>Edit Profile</span>
          </a>
          <a href="/orders" class="account-nav-link">
            <span class="account-nav-icon"><i class="fas fa-box"></i></span>
            <span>My Orders</span>
          </a>
          <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
            <a href="#messages" class="account-nav-link">
              <span class="account-nav-icon"><i class="fas fa-envelope"></i></span>
              <span>Messages</span>
              <span class="account-msg-badge"><%= messages.filter(m => !m.read).length || messages.length %></span>
            </a>
          <% } %>
          <a href="/logout" class="account-nav-link logout">
            <span class="account-nav-icon"><i class="fas fa-sign-out-alt"></i></span>
            <span>Logout</span>
          </a>
        </nav>

        <div class="account-quick-stats">
          <div class="account-stat-card">
            <i class="fas fa-calendar-alt"></i>
            <div>
              <span class="account-stat-label">Member Since</span>
              <span class="account-stat-value"><%= customer.created_at ? new Date(customer.created_at).toLocaleDateString('en-IN', { month: 'short', year: 'numeric' }) : 'N/A' %></span>
            </div>
          </div>
          <div class="account-stat-card">
            <i class="fas fa-map-marker-alt"></i>
            <div>
              <span class="account-stat-label">Location</span>
              <span class="account-stat-value"><%= (customer.city && customer.state) ? customer.city + ', ' + customer.state : 'Not set' %></span>
            </div>
          </div>
        </div>
      </aside>

      <!-- ========== MAIN CONTENT ========== -->
      <main class="account-main">

        <!-- Messages -->
        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
          <div class="account-section" id="messages">
            <div class="account-section-header">
              <div class="account-section-icon"><i class="fas fa-envelope"></i></div>
              <h2>Messages</h2>
              <span class="account-section-count"><%= messages.filter(m => !m.read).length %> unread</span>
            </div>
            <div class="account-messages-list">
              <% messages.forEach(msg => { %>
                <div class="account-msg-card <%= msg.read ? '' : 'unread' %>">
                  <div class="account-msg-dot"></div>
                  <div class="account-msg-content">
                    <div class="account-msg-top">
                      <h4><%= msg.subject %></h4>
                      <span class="account-msg-date"><%= new Date(msg.created_at).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'}) %></span>
                    </div>
                    <p class="account-msg-order">Regarding order #<%= msg.order_number %></p>
                    <p class="account-msg-body"><%= msg.message %></p>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <!-- Profile Form -->
        <div class="account-section">
          <div class="account-section-header">
            <div class="account-section-icon"><i class="fas fa-user-edit"></i></div>
            <h2>Edit Profile</h2>
          </div>

          <% if (success) { %>
            <div class="account-toast success"><i class="fas fa-check-circle"></i> <%= success %></div>
          <% } %>
          <% if (error) { %>
            <div class="account-toast error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
          <% } %>

          <form action="/account" method="POST" class="account-form">
            <details class="account-form-section" open>
              <summary class="account-form-section-title">
                <span class="account-form-section-icon"><i class="fas fa-id-card"></i></span>
                Personal Information
                <i class="fas fa-chevron-down account-form-chevron"></i>
              </summary>
              <div class="account-form-grid">
                <div class="account-form-group">
                  <label>Full Name</label>
                  <input type="text" name="name" value="<%= customer.name %>" required placeholder="Your full name">
                </div>
                <div class="account-form-group">
                  <label>Email Address</label>
                  <input type="email" name="email" value="<%= customer.email %>" required placeholder="you@example.com">
                </div>
                <div class="account-form-group">
                  <label>Phone Number</label>
                  <input type="tel" name="phone" value="<%= customer.phone %>" required pattern="[0-9]{10}" placeholder="10-digit mobile number">
                </div>
              </div>
            </details>

            <details class="account-form-section">
              <summary class="account-form-section-title">
                <span class="account-form-section-icon"><i class="fas fa-map-marked-alt"></i></span>
                Delivery Address
                <i class="fas fa-chevron-down account-form-chevron"></i>
              </summary>
              <div class="account-form-grid">
                <div class="account-form-group full">
                  <label>Street Address</label>
                  <textarea name="address" rows="2" placeholder="Street address, landmark..."><%= customer.address || '' %></textarea>
                </div>
                <div class="account-form-group">
                  <label>City</label>
                  <input type="text" name="city" value="<%= customer.city || '' %>" placeholder="City">
                </div>
                <div class="account-form-group">
                  <label>State</label>
                  <input type="text" name="state" value="<%= customer.state || '' %>" placeholder="State">
                </div>
                <div class="account-form-group">
                  <label>Pincode</label>
                  <input type="text" name="pincode" value="<%= customer.pincode || '' %>" placeholder="6-digit pincode" pattern="[0-9]{6}">
                </div>
              </div>
            </details>

            <details class="account-form-section">
              <summary class="account-form-section-title">
                <span class="account-form-section-icon"><i class="fas fa-shield-alt"></i></span>
                Security
                <i class="fas fa-chevron-down account-form-chevron"></i>
              </summary>
              <div class="account-form-grid">
                <div class="account-form-group full">
                  <label>Current Password</label>
                  <input type="password" name="current_password" placeholder="Enter current password to change">
                </div>
                <div class="account-form-group full">
                  <label>New Password</label>
                  <input type="password" name="new_password" placeholder="Min 6 characters" minlength="6">
                </div>
              </div>
            </details>

            <div class="account-form-actions">
              <button type="submit" class="btn btn-primary btn-glow">
                <i class="fas fa-save"></i> Save Changes
              </button>
            </div>
          </form>
        </div>

      </main>
    </div>
  </div>
</section>

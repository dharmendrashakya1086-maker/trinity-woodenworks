<%- include('partials/header') %>

<section class="page-header">
  <div class="container">
    <h1>My Account</h1>
    <p>Manage your profile and settings</p>
    <div class="breadcrumb">
      <a href="/">Home</a> <i class="fas fa-chevron-right"></i> <span>Account</span>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="account-layout">
      <div class="account-sidebar">
        <div class="account-user">
          <div class="account-avatar"><i class="fas fa-user"></i></div>
          <h3><%= customer.name %></h3>
          <p><%= customer.email %></p>
        </div>
        <nav class="account-nav">
          <a href="/account" class="account-nav-link active"><i class="fas fa-user-edit"></i> Edit Profile</a>
          <a href="/orders" class="account-nav-link"><i class="fas fa-box"></i> My Orders</a>
          <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
            <a href="#messages" class="account-nav-link"><i class="fas fa-envelope"></i> Messages <span class="msg-badge"><%= messages.filter(m => !m.read).length || messages.length %></span></a>
          <% } %>
          <a href="/logout" class="account-nav-link logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </nav>
      </div>

      <div class="account-main">
        <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
          <div class="card" style="margin-bottom:24px;">
            <div class="card-header">
              <h2><i class="fas fa-envelope"></i> Messages from Trinity Woodenworks</h2>
            </div>
            <div class="card-body">
              <% messages.forEach(msg => { %>
                <div class="account-message-card <%= msg.read ? '' : 'unread' %>">
                  <div class="account-message-header">
                    <div>
                      <h4><%= msg.subject %></h4>
                      <p>Regarding order #<%= msg.order_number %></p>
                    </div>
                    <span class="account-message-date"><%= new Date(msg.created_at).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'}) %></span>
                  </div>
                  <p class="account-message-body"><%= msg.message %></p>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <div class="card">
          <div class="card-header">
            <h2><i class="fas fa-user-edit"></i> Edit Profile</h2>
          </div>
          <div class="card-body">
            <% if (success) { %>
              <div class="auth-success"><i class="fas fa-check-circle"></i> <%= success %></div>
            <% } %>
            <% if (error) { %>
              <div class="auth-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
            <% } %>

            <form action="/account" method="POST" class="auth-form">
              <div class="form-row">
                <div class="form-group">
                  <label>Full Name</label>
                  <input type="text" name="name" value="<%= customer.name %>" required>
                </div>
                <div class="form-group">
                  <label>Email Address</label>
                  <input type="email" name="email" value="<%= customer.email %>" required>
                </div>
              </div>
              <div class="form-group">
                <label>Phone Number</label>
                <input type="tel" name="phone" value="<%= customer.phone %>" required pattern="[0-9]{10}">
              </div>
              <div class="form-group">
                <label>Delivery Address</label>
                <textarea name="address" rows="2" placeholder="Street address, landmark..."><%= customer.address || '' %></textarea>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>City</label>
                  <input type="text" name="city" value="<%= customer.city || '' %>" placeholder="City">
                </div>
                <div class="form-group">
                  <label>State</label>
                  <input type="text" name="state" value="<%= customer.state || '' %>" placeholder="State">
                </div>
                <div class="form-group">
                  <label>Pincode</label>
                  <input type="text" name="pincode" value="<%= customer.pincode || '' %>" placeholder="6-digit pincode" pattern="[0-9]{6}">
                </div>
              </div>

              <h3 class="form-section-title"><i class="fas fa-lock"></i> Change Password</h3>
              <div class="form-group">
                <label>Current Password</label>
                <input type="password" name="current_password" placeholder="Enter current password to change">
              </div>
              <div class="form-group">
                <label>New Password</label>
                <input type="password" name="new_password" placeholder="Min 6 characters" minlength="6">
              </div>

              <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>



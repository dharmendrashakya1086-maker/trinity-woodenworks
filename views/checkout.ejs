const stateNames = Object.keys(statesData).sort();

// ================================================================
// POPULATE STATE DROPDOWN
// ================================================================
function populateStates() {
  const container = document.getElementById('stateOptions');
  container.innerHTML = stateNames.map(s =>
    `<div class="dropdown-item" data-value="${s}" onclick="selectState('${s}')">${s}</div>`
  ).join('');
}

// ================================================================
// POPULATE CITY DROPDOWN
// ================================================================
function populateCities(state) {
  const container = document.getElementById('cityOptions');
  const cities = statesData[state] || [];
  if (cities.length === 0) {
    container.innerHTML = '<div class="dropdown-empty">No cities available</div>';
  } else {
    container.innerHTML = cities.sort().map(c =>
      `<div class="dropdown-item" data-value="${c}" onclick="selectCity('${c.replace(/'/g, "\\'")}')">${c}</div>`
    ).join('');
  }
}

// ================================================================
// DROPDOWN TOGGLE
// ================================================================
function toggleDropdown(id) {
  const dd = document.getElementById(id);
  const isOpen = dd.classList.contains('open');
  closeAllDropdowns();
  if (!isOpen) {
    dd.classList.add('open');
    const searchInput = dd.querySelector('.dropdown-search input');
    if (searchInput) { searchInput.value = ''; searchInput.focus(); }
    filterDropdown(searchInput, id);
  }
}

function closeAllDropdowns() {
  document.querySelectorAll('.custom-dropdown').forEach(d => d.classList.remove('open'));
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('.custom-dropdown')) closeAllDropdowns();
});

// ================================================================
// FILTER DROPDOWN
// ================================================================
function filterDropdown(input, dropdownId) {
  const term = input.value.toLowerCase();
  const items = document.getElementById(dropdownId).querySelectorAll('.dropdown-item');
  let hasVisible = false;
  items.forEach(item => {
    const match = item.textContent.toLowerCase().includes(term);
    item.style.display = match ? '' : 'none';
    if (match) hasVisible = true;
  });
  const emptyMsg = document.getElementById(dropdownId).querySelector('.dropdown-empty');
  if (emptyMsg) emptyMsg.style.display = hasVisible ? 'none' : (term ? 'block' : 'none');
  if (emptyMsg && !term) emptyMsg.style.display = 'none';
}

// ================================================================
// SELECT STATE
// ================================================================
function selectState(state) {
  document.getElementById('inputState').value = state;
  document.getElementById('inputCity').value = '';
  document.getElementById('inputCity').placeholder = 'Select City';
  populateCities(state);
  closeAllDropdowns();
  clearError('state');
  // Reset city
  document.getElementById('citySearch').value = '';
}

// ================================================================
// SELECT CITY
// ================================================================
function selectCity(city) {
  document.getElementById('inputCity').value = city;
  closeAllDropdowns();
  clearError('city');
}

// ================================================================
// FORM VALIDATION
// ================================================================
function showError(field, msg) {
  const errEl = document.getElementById(field + 'Error');
  if (errEl) errEl.textContent = msg;
  const input = document.getElementById('input' + field.charAt(0).toUpperCase() + field.slice(1));
  if (input) input.classList.add('input-error');
}

function clearError(field) {
  const errEl = document.getElementById(field + 'Error');
  if (errEl) errEl.textContent = '';
  const input = document.getElementById('input' + field.charAt(0).toUpperCase() + field.slice(1));
  if (input) input.classList.remove('input-error');
}

// Name: only letters and spaces
document.getElementById('inputName').addEventListener('input', function() {
  this.value = this.value.replace(/[^a-zA-Z\s]/g, '');
  clearError('name');
});

// Phone: only digits, max 10
document.getElementById('inputPhone').addEventListener('input', function() {
  this.value = this.value.replace(/[^0-9]/g, '').substring(0, 10);
  clearError('phone');
});

// Pincode: only digits, max 6
document.getElementById('inputPincode').addEventListener('input', function() {
  this.value = this.value.replace(/[^0-9]/g, '').substring(0, 6);
  clearError('pincode');
});

// ================================================================
// USE MY LOCATION (Geolocation)
// ================================================================
function useMyLocation() {
  const btn = document.getElementById('useLocationBtn');
  const status = document.getElementById('locationStatus');

  if (!navigator.geolocation) {
    status.innerHTML = '<i class="fas fa-exclamation-circle"></i> Geolocation not supported by your browser';
    status.className = 'location-status error';
    return;
  }

  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Detecting Location...';
  status.innerHTML = '<i class="fas fa-info-circle"></i> Please allow location access when prompted';
  status.className = 'location-status loading';

  navigator.geolocation.getCurrentPosition(
    async function(position) {
      const lat = position.coords.latitude;
      const lon = position.coords.longitude;
      const accuracy = position.coords.accuracy;

      try {
        // Use OpenStreetMap Nominatim API with high precision params
        const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&addressdetails=1&extratags=1&namedetails=1`, {
          headers: { 'Accept-Language': 'en' }
        });
        const data = await res.json();
        const addr = data.address || {};

        // Fill address
        const parts = [];
        if (addr.house_number) parts.push(addr.house_number);
        if (addr.road) parts.push(addr.road);
        if (addr.suburb || addr.neighbourhood) parts.push(addr.suburb || addr.neighbourhood);
        if (addr.city_district) parts.push(addr.city_district);
        document.getElementById('inputAddress').value = parts.join(', ') || data.display_name || '';

        // Fill city
        const city = addr.city || addr.town || addr.village || addr.county || '';
        if (city) {
          // Try to match with our state data
          const stateName = addr.state || '';
          const matchedState = stateNames.find(s => s.toLowerCase() === stateName.toLowerCase());
          if (matchedState) {
            selectState(matchedState);
            // Try to match city
            const cities = statesData[matchedState] || [];
            const matchedCity = cities.find(c => c.toLowerCase() === city.toLowerCase());
            if (matchedCity) {
              selectCity(matchedCity);
            } else {
              document.getElementById('inputCity').value = city;
            }
          }
        }

        // Fill pincode
        if (addr.postcode) {
          document.getElementById('inputPincode').value = addr.postcode.replace(/[^0-9]/g, '').substring(0, 6);
        }

        // Fill phone prefix is already +91

        status.innerHTML = '<i class="fas fa-check-circle"></i> Location detected successfully!';
        status.className = 'location-status success';
        btn.innerHTML = '<i class="fas fa-map-marker-alt"></i> Use My Location';
        btn.disabled = false;

      } catch (err) {
        status.innerHTML = '<i class="fas fa-exclamation-circle"></i> Could not fetch address. Please fill manually.';
        status.className = 'location-status error';
        btn.innerHTML = '<i class="fas fa-map-marker-alt"></i> Use My Location';
        btn.disabled = false;
      }
    },
    function(error) {
      let msg = 'Location access denied. Please fill address manually.';
      if (error.code === 1) msg = 'Location permission denied. Please allow location access in your browser settings.';
      else if (error.code === 2) msg = 'Location unavailable. Please fill address manually.';
      else if (error.code === 3) msg = 'Location request timed out. Please try again.';
      status.innerHTML = '<i class="fas fa-exclamation-circle"></i> ' + msg;
      status.className = 'location-status error';
      btn.innerHTML = '<i class="fas fa-map-marker-alt"></i> Use My Location';
      btn.disabled = false;
    },
    { enableHighAccuracy: true, timeout: 30000, maximumAge: 0 }
  );
}

// ================================================================
// FORM SUBMIT
// ================================================================
document.getElementById('checkoutForm').addEventListener('submit', function(e) {
  e.preventDefault();

  let valid = true;

  // Name validation
  const name = document.getElementById('inputName').value.trim();
  if (!name || name.length < 2) {
    showError('name', 'Please enter a valid name (min 2 characters, letters only)');
    valid = false;
  } else { clearError('name'); }

  // Email validation
  const email = document.getElementById('inputEmail').value.trim();
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!email || !emailRegex.test(email)) {
    showError('email', 'Please enter a valid email address');
    valid = false;
  } else { clearError('email'); }

  // Phone validation
  const phone = document.getElementById('inputPhone').value.trim();
  if (!phone || phone.length !== 10 || !/^[6-9]\d{9}$/.test(phone)) {
    showError('phone', 'Please enter a valid 10-digit Indian mobile number');
    valid = false;
  } else { clearError('phone'); }

  // Address validation
  const address = document.getElementById('inputAddress').value.trim();
  if (!address || address.length < 10) {
    showError('address', 'Please enter a complete address (min 10 characters)');
    valid = false;
  } else { clearError('address'); }

  // State validation
  const state = document.getElementById('inputState').value.trim();
  if (!state) {
    showError('state', 'Please select a state');
    valid = false;
  } else { clearError('state'); }

  // City validation
  const city = document.getElementById('inputCity').value.trim();
  if (!city) {
    showError('city', 'Please select a city');
    valid = false;
  } else { clearError('city'); }

  // Pincode validation
  const pincode = document.getElementById('inputPincode').value.trim();
  if (!pincode || pincode.length !== 6 || !/^\d{6}$/.test(pincode)) {
    showError('pincode', 'Please enter a valid 6-digit pincode');
    valid = false;
  } else { clearError('pincode'); }

  if (!valid) return;

  const btn = document.getElementById('placeOrderBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

  const formData = new FormData(this);
  const data = Object.fromEntries(formData);

  fetch('/api/orders/place', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      window.location.href = '/order-confirmation/' + data.order_number;
    } else {
      alert(data.error || 'Failed to place order');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-check-circle"></i> Place Order';
    }
  })
  .catch(() => {
    alert('Something went wrong');
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-check-circle"></i> Place Order';
  });
});

// Payment option toggle
document.querySelectorAll('.payment-option').forEach(opt => {
  opt.addEventListener('click', function() {
    document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('active'));
    this.classList.add('active');
    this.querySelector('input').checked = true;
  });
});

// Init
populateStates();

// Pre-fill state/city from saved address
const savedState = document.getElementById('inputState').value;
const savedCity = document.getElementById('inputCity').value;
if (savedState && statesData[savedState]) {
  selectState(savedState);
  if (savedCity) {
    setTimeout(() => selectCity(savedCity), 100);
  }
}
</script>

